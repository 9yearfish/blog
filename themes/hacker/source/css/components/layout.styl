$bodyBgCommonColor = #f7f7f7
$mainBgCommonColor = #ffffff

$bodyBgDarkColor = #111111
$mainBgDarkColor = #1a1a1a

html
  font-size 10px
  -webkit-text-size-adjust 100%

p
h1
h2
h3
h4
h5
h6
  margin 0

a
  text-decoration none


body
  background-color $bodyBgCommonColor
  font-family "Segoe UI", "Lucida Grande", Helvetica, "Microsoft YaHei", FreeSans, Arimo, "Droid Sans","wenquanyi micro hei","Hiragino Sans GB", "Hiragino Sans GB W3", Arial, sans-serif
  -moz-osx-font-smoothing grayscale
  -webkit-font-smoothing antialiased
  overflow-x hidden

  .blog
    max-width 1170px
    min-height 100vh
    background-color $mainBgCommonColor
    margin: 0 auto

    .content
      box-sizing border-box
      max-width 770px
      width 100%
      padding: 80px 10px 10px;
      margin 0 auto

@media (prefers-color-scheme dark)
  body
    background-color $bodyBgDarkColor

    .blog
      background-color $mainBgDarkColor

// gentle entrance for every page's main content
@keyframes contentRise
  from
    opacity 0
    transform translateY(14px)
  to
    opacity 1
    transform translateY(0)

.content > article
  animation contentRise 0.5s ease both

// honor "reduce motion" — disable all animation/transition
@media (prefers-reduced-motion: reduce)
  *
  *:before
  *:after
    animation-duration 0.001ms !important
    animation-delay 0ms !important
    transition-duration 0.001ms !important
