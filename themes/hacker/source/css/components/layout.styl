$bodyBgCommonColor = #f7f7f7
$mainBgCommonColor = #ffffff

$bodyBgDarkColor = #111111
$mainBgDarkColor = #1a1a1a

html
  font-size 10px
  -webkit-text-size-adjust 100%

p
h1
h2
h3
h4
h5
h6
  margin 0

a
  text-decoration none


body
  background-color $bodyBgCommonColor
  font-family "Segoe UI", "Lucida Grande", Helvetica, "Microsoft YaHei", FreeSans, Arimo, "Droid Sans","wenquanyi micro hei","Hiragino Sans GB", "Hiragino Sans GB W3", Arial, sans-serif
  -moz-osx-font-smoothing grayscale
  -webkit-font-smoothing antialiased
  overflow-x hidden

  .blog
    max-width 1170px
    min-height 100vh
    background-color $mainBgCommonColor
    margin: 0 auto

    .content
      box-sizing border-box
      max-width 770px
      width 100%
      padding: 80px 10px 10px;
      margin 0 auto

@media (prefers-color-scheme dark)
  body
    background-color $bodyBgDarkColor

    .blog
      background-color $mainBgDarkColor

// ── page entrances ──────────────────────────────────────────
@keyframes riseIn
  from
    opacity 0
    transform translateY(14px)
  to
    opacity 1
    transform translateY(0)

@keyframes badgePop
  from
    opacity 0
    transform scale(0.9)
  to
    opacity 1
    transform scale(1)

// home: each post fades up, lightly staggered
.posts-loop.on-home > article
  opacity 0
  animation riseIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) both

  for n in (1..12)
    &:nth-child({n})
      animation-delay (n * 0.06s)

// single-article pages: choreograph the article's parts (title → meta → 正文 …)
.posts-loop.on-post > article > *,
.posts-loop.on-page > article > *
  opacity 0
  animation riseIn 0.52s cubic-bezier(0.22, 1, 0.36, 1) both

  for n in (1..8)
    &:nth-child({n})
      animation-delay (n * 0.09s)

// recording badge gets a gentle pop instead of a rise
.posts-loop.on-post > article > .recording-note
  animation-name badgePop

// honor "reduce motion" — disable all animation/transition
@media (prefers-reduced-motion: reduce)
  *
  *:before
  *:after
    animation-duration 0.001ms !important
    animation-delay 0ms !important
    transition-duration 0.001ms !important
