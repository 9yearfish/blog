$archiveTitleCommonColor = #4a4a4a
$archiveTitleLinkCommonColor = #4a4a4a
$archiveYearCommonColor = #3f3f3f
$archiveDividerCommonColor = #ececec
// darkened from #9e9e9e (~2.8:1) to pass WCAG AA
$archiveTitleTimeCommonColor = #6b6b6b
$archiveTitleTimeHoverCommonColor = #F03838

$archiveTitleDarkColor = #f6f2f5
$archiveTitleLinkDarkColor = #ffffff
$archiveYearDarkColor = #ffffff
$archiveDividerDarkColor = #2a262d
$archiveTitleTimeDarkColor = #9a9aa0
$archiveTitleTimeHoverDarkColor = #F03838

article.archive
  padding 0
  margin 2em auto

// year heading — groups the flat list into a scannable history
.archive-year
  font-size 3em
  font-weight 700
  line-height 1
  color $archiveYearCommonColor
  margin 2.4em 0 0.9em
  padding-bottom 0.3em
  border-bottom 1px solid $archiveDividerCommonColor

  &:first-child
    margin-top 0.3em

// "date + title" rows — airy index, easy to scan
.archive-post
  display flex
  align-items baseline
  gap 1.7rem
  text-align left
  margin 1.15em 0

  time
    flex 0 0 auto
    font-style normal

    a
      font-size 1.5rem
      color $archiveTitleTimeCommonColor
      white-space nowrap

      &:before
        content '#'
      &:hover
        color $archiveTitleTimeHoverCommonColor

  .archive-title
    flex 1 1 auto
    min-width 0           // let long titles wrap instead of overflowing the flex row
    font-size 2em
    line-height 1.5
    margin 0
    color $archiveTitleCommonColor
    overflow-wrap break-word
    word-break break-word

    a
      color $archiveTitleLinkCommonColor

      span
        padding-bottom 3px
        -webkit-transition box-shadow 0.15s
        transition box-shadow 0.15s
        box-shadow inset 0 -2px 0 rgba(240, 56, 56, 0)

      &:hover span
        box-shadow inset 0 -2px 0 rgba(240, 56, 56, 0.4)

// mobile: shrink type so titles never clip the viewport
@media (max-width: 768px)
  .archive-year
    font-size 2.4em
    margin 1.8em 0 0.7em

  .archive-post
    gap 1.2rem
    margin 0.95em 0

    time a
      font-size 1.4rem
    .archive-title
      font-size 1.7em
      line-height 1.5

@media (prefers-color-scheme dark)
  .archive-year
    color $archiveYearDarkColor
    border-bottom-color $archiveDividerDarkColor

  .archive-post
    .archive-title
      color $archiveTitleDarkColor

      a
        color $archiveTitleLinkDarkColor

    time
      a
        color $archiveTitleTimeDarkColor

        &:hover
          color $archiveTitleTimeHoverDarkColor

// entrance: each year + row fades up, lightly staggered
@keyframes archiveItemIn
  from
    opacity 0
    transform translateY(10px)
  to
    opacity 1
    transform translateY(0)

.archive
  .archive-year,
  .archive-item
    animation archiveItemIn 0.5s ease both

  for n in (1..16)
    > *:nth-child({n})
      animation-delay (n * 0.04s)

  // hover: row nudges right, date warms up
  .archive-post
    transition transform 0.18s ease

    &:hover
      transform translateX(4px)
